# =============================================================================
# Public Site
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SysDesign Gym

# =============================================================================
# Supabase (REQUIRED for auth + persistence)
# https://supabase.com -> Project Settings -> API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxx

# =============================================================================
# Anthropic Claude (REQUIRED for AI grading)
# https://console.anthropic.com
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_GRADING_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-opus-4-6

# =============================================================================
# OpenAI (optional, used as fallback STT for mock interviewer in Phase 2)
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# =============================================================================
# Stripe (OPTIONAL — paywall runs in mock mode if these are blank)
# https://dashboard.stripe.com -> Developers -> API keys
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_STUDENT_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxxx

# =============================================================================
# Feature flags
# =============================================================================
# When true, paywall is bypassed and all problems are accessible (useful in dev)
NEXT_PUBLIC_BYPASS_PAYWALL=false
# When true, AI grading returns a deterministic mock response (no API spend)
MOCK_GRADING=false
